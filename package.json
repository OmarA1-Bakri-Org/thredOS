{
  "name": "threader",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "description": "thredOS Desktop local-first control surface for agent work",
  "main": "desktop/main.cjs",
  "bin": {
    "thread": "./lib/seqctl/index.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build/next-build.mjs",
    "start": "next start",
    "desktop:dev": "electron ./desktop/main.cjs",
    "desktop:build": "bun run build && electron-builder --win nsis",
    "desktop:dist": "electron-builder",
    "lint": "eslint --cache --cache-strategy content --cache-location .eslintcache --concurrency auto app components lib test desktop scripts/build scripts/verify eslint.config.mjs next.config.ts playwright.config.ts playwright.dev-verify.config.ts playwright.release-live.config.ts playwright.verify.shared.ts proxy.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:ui": "playwright test test/ui/main-page.e2e.ts",
    "check": "bun run lint && bun run typecheck && bun test",
    "verify:local": "node scripts/verify/run.mjs local",
    "verify:ci": "node scripts/verify/run.mjs ci",
    "verify:release-live": "node scripts/verify/run.mjs release-live"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.20",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.36.0",
    "next": "16.1.2",
    "next-themes": "^0.4.6",
    "openai": "^6.27.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.2",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "latest",
    "electron-builder": "latest",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "ai.thredos.desktop",
    "productName": "thredOS Desktop",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      ".next/**/*",
      "app/**/*",
      "components/**/*",
      "desktop/**/*",
      "lib/**/*",
      "public/**/*",
      "package.json",
      "next.config.*",
      "postcss.config.*"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "protocols": [
      {
        "name": "thredOS Activation",
        "schemes": [
          "thredos"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
