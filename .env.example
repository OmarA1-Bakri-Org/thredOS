# ThreadOS API/UI base path.
# Optional. Defaults to current working directory if unset.
THREADOS_BASE_PATH=./

# Custom mprocs binary path.
# Optional. Leave empty to use the built-in default resolution.
THREADOS_MPROCS_PATH=

# Anthropic API key for chat intelligence features.
# Optional for local CLI-only workflows; required for live Anthropic-backed chat responses.
ANTHROPIC_API_KEY=
