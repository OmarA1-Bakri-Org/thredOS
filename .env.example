# ThreadOS API/UI base path.
# Optional. Defaults to current working directory if unset.
THREADOS_BASE_PATH=./

# Desktop shell launch toggles.
# Optional. These power the thredOS Desktop wrapper and browser-based activation flow.
THREDOS_DESKTOP=true
THREDOS_DESKTOP_HOST=127.0.0.1
THREDOS_DESKTOP_PORT=3010
THREDOS_DESKTOP_APP_URL=http://127.0.0.1:3010/app
THREDOS_DESKTOP_RETURN_URL=thredos://activate
THREDOS_DESKTOP_BROWSER_RETURN_PATH=/desktop/activate
THREDOS_ACTIVATION_SECRET=

# Hosted desktop activation providers.
THREDOS_CLERK_SIGN_IN_URL=
THREDOS_CLERK_SIGN_UP_URL=
THREDOS_STRIPE_SECRET_KEY=
THREDOS_STRIPE_PUBLISHABLE_KEY=
THREDOS_STRIPE_PRICE_ID=
THREDOS_STRIPE_CHECKOUT_MODE=subscription
THREDOS_STRIPE_WEBHOOK_SECRET=

# Thread Runner remains disabled for the thredOS Desktop public beta by default.
THREDOS_ENABLE_THREAD_RUNNER=false
THREDOS_ALLOW_PROCESS_CONTROLS=false

# Custom mprocs binary path.
# Optional. Leave empty to use the built-in default resolution.
THREADOS_MPROCS_PATH=

# ── Model selection (preferred) ──────────────────────────────────────
# Pick any model by ID. The system auto-routes to the correct backend.
# Examples: gpt-4o, claude-sonnet-4-20250514, meta-llama/llama-3.1-70b
THREADOS_MODEL=gpt-4o

# ── API keys ────────────────────────────────────────────────────────
# Set the key(s) for your model's backend. OpenRouter works as a universal relay.

# Direct OpenAI access (for gpt-*, o1-*, o3-*, o4-* models)
OPENAI_API_KEY=

# OpenRouter relay (universal — supports 100+ models including Claude, Llama, Gemini)
OPENROUTER_API_KEY=
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=thredOS

# Direct Anthropic access (future — currently routed via OpenRouter)
ANTHROPIC_API_KEY=

# ── Legacy config (still works, but THREADOS_MODEL is preferred) ────
# THREADOS_LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o
# OPENROUTER_MODEL=openai/gpt-4o

# Never commit real credentials; keep placeholders here and use local files/secrets in real environments.
