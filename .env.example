# ThreadOS API/UI base path.
# Optional. Defaults to current working directory if unset.
THREADOS_BASE_PATH=./

# Custom mprocs binary path.
# Optional. Leave empty to use the built-in default resolution.
THREADOS_MPROCS_PATH=

# Anthropic API key for chat intelligence features.
# Optional for local CLI-only workflows; required for live Anthropic-backed chat responses.
ANTHROPIC_API_KEY=

# LLM provider selection for model-backed runtime integrations.
# Optional. Defaults can be defined by the app/provider layer.
THREADOS_LLM_PROVIDER=openai

# OpenAI provider settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# OpenRouter provider settings.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=ThreadOS

# Never commit real credentials; keep placeholders here and use local files/secrets in real environments.
